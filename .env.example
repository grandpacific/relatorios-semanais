# GrandPacific — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no repositório

# ── Claude / Anthropic ──────────────────────────────────────────────────────
# Obter em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Sanity CMS ──────────────────────────────────────────────────────────────
# Project ID: Sanity Dashboard → seu projeto → Settings → API
SANITY_PROJECT_ID=abc123xyz
SANITY_DATASET=production
# Token com permissão de escrita: Settings → API → Tokens → Add API Token (Editor)
SANITY_API_TOKEN=sk...

# ── Alpha Vantage (preços de commodities e câmbio) ──────────────────────────
# Gratuito (25 req/dia): https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_KEY=XXXXXXXXXX

# ── OpenWeatherMap (clima nas regiões agrícolas) ────────────────────────────
# Gratuito (1000 req/dia): https://home.openweathermap.org/api_keys
OPEN_WEATHER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notificações de falha (opcional) ───────────────────────────────────────
MAIL_USERNAME=automacao@grandpacific.com.br
MAIL_PASSWORD=...
MAIL_NOTIFY=time@grandpacific.com.br
